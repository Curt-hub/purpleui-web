{
  "name": "Logos",
  "type": "foundation",
  "description": "Purple brand logos. Stored as local SVGs in /public/logo/ (permanent, no CDN dependency).",
  "assetDirectory": "public/logo/",
  "format": "SVG",
  "variants": [
    "logo-light (for dark backgrounds)",
    "logo-dark (for light backgrounds)",
    "logo-mark (icon only)"
  ],
  "usage": {
    "web": "<img src='/logo/{variant}.svg' alt='Purple' />",
    "ios": "Image('{variant}') from asset catalog",
    "android": "R.drawable.{variant}"
  },
  "docPage": "/foundation/logos"
}
